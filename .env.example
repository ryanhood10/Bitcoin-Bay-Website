# Bitcoin Bay — example env file. Copy to .env and fill in real values.
# CLAUDE.md has the authoritative env-var table; this file is a quick-start
# scaffold for fresh clones. NEVER commit a populated .env.

# ─── Core ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/bcbay
NODE_ENV=development
PORT=8800

# ─── Email (Gandi mailbox — sends welcome, reset, ops alerts) ────────────
EMAIL=ops@bitcoinbay.com
EMAIL_PASSWORD=
OPS_ALERT_EMAIL=

# ─── reCAPTCHA (server secret, v2) ───────────────────────────────────────
GoogleCaptchaSecretKey=
# RECAPTCHA_SECRET=  # alternative name, either works

# ─── Wager backend (price-per-head proxy) ────────────────────────────────
AGENT_USERNAME=
AGENT_PASSWORD=
AGENT_TOTP_SECRET=                  # base32 2FA seed from the wager portal
AGENT_TOKEN=                        # optional JWT seed

# ─── Admin auth (env-var admin; additional admins live in bcb_admin_users) ─
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=                # bcrypt hash, NOT the plaintext
ADMIN_SESSION_SECRET=               # 32+ chars, HMAC cookie signing key

# ─── Mongo for /admin/dashboard (usually same cluster as MONGO_URI) ──────
MONGO_AUTOMATION_URI=
MONGO_AUTOMATION_DB=bcbay_automation

# ─── Instagram OAuth (Meta Login) ────────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://bitcoinbay.com/auth/instagram/callback
INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_content_publish
INSTAGRAM_ACCOUNT_HANDLE=bitcoin_bay

# ─── Operator alerts (Pushover preferred, Twilio is fallback) ────────────
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_FROM_NUMBER=
OPERATOR_PHONE_NUMBER=
SMS_QUIET_HOURS=22-8                # 10pm–8am in SMS_TIMEZONE
SMS_TIMEZONE=America/Chicago

# ─── Content drafter (Phase 3+) ──────────────────────────────────────────
ANTHROPIC_API_KEY=                  # required for /admin/dashboard/content
BCBAY_DRAFTER_MODEL=claude-sonnet-4-6  # optional override
PEXELS_API_KEY=                     # tier-2 photo source (free)
UNSPLASH_ACCESS_KEY=                # tier-3 photo source (free)

# ─── AI scene generation (operator-triggered 🎨 button, ~$0.05/call) ─────
REPLICATE_API_TOKEN=                # absent = 🎨 button returns 503
BCBAY_REPLICATE_MODEL=zsxkib/instant-id   # optional override
